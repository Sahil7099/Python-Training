a = float(input("Enter first number: "))
b = float(input("Enter second number: "))
operator = input("Enter operator (+, *, /, -): ")

if operator == "+":
    print("result = ", a + b)
elif operator == "*":
    print("result = ", a * b)
elif operator == "/":
    print("result = ", a / b)
elif operator == "-":
    print("result = ", a - b)
else:
    print("Invalid operator entered.")
